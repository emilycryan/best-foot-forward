---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import CategoryVisual from '../components/CategoryVisual.astro';
import { FUN_CATEGORIES } from '../lib/fun-categories';

const pages = await getCollection('fun');

const cats = [...FUN_CATEGORIES]
  .sort((a, b) => a.order - b.order)
  .map((c) => {
    const page = pages.find((p) => p.id === c.key);
    return { ...c, image: page?.data.image, imageAlt: page?.data.imageAlt, count: page?.data.picks?.length ?? 0 };
  });

const statLabel = (count: number) => (count === 0 ? 'New' : `${count} ${count === 1 ? 'pick' : 'picks'}`);
---
<Base title="The Fun Stuff" current="fun" description="Shows, snacks, impulse buys, and small joys. The lighter side of being stuck on the couch.">
  <div class="page">
    <h1>The Fun Stuff</h1>
    <p style="color:var(--base)">Shows, snacks, impulse buys, and small joys. The lighter side of being stuck on the couch.</p>
    <div class="proto-grid">
      {cats.map((c) => (
        <a class="proto-tile" href={`/fun/${c.key}`} style={`color: var(--${c.color})`}>
          <span class="pv" style={`background: var(--${c.color}-light)`}>
            <CategoryVisual icon={c.icon} image={c.image} imageAlt={c.imageAlt} />
          </span>
          <h2>{c.label}</h2>
          <p class="blurb">{c.blurb}</p>
          <span class="stat">{statLabel(c.count)} <span class="arr">→</span></span>
        </a>
      ))}
    </div>
  </div>
</Base>
